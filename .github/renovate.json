{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "default:automergeDigest",
    "docker:pinDigests"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    }
  ],
  "argocd": {
    "managerFilePatterns": [
      "/apps/templates/.+\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/apps/templates/.+\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "/apps/templates/helm-factorio.yaml$/"
      ],
      "matchStrings": [
        "#\\s?renovate: image=(?<depName>.*?)\\s+?tag:\\s?\\\"?(?<currentValue>[\\w+\\.\\-]*)(@(?<currentDigest>sha256:[0-9a-f]*))?\\\"?"
      ],
      "versioningTemplate": "loose"
    }
  ]
}
